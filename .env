# RViz2 Web Visualization 环境配置

# ROS2 通信域 ID；只有相同 Domain ID 的 ROS2 节点才能互相发现
ROS_DOMAIN_ID=0

# 预留的独立 Rosbridge 端口；当前前端实际通过后端 /ws 通信
ROSBRIDGE_PORT=9090

# FastAPI 后端监听端口
BACKEND_PORT=8000

# Vite 前端开发服务器监听端口
FRONTEND_PORT=3000

# 开发模式文件监听器不足时使用轮询；正常启动模式不使用
CHOKIDAR_USEPOLLING=true

# 开发模式前端文件轮询间隔，单位为毫秒
CHOKIDAR_INTERVAL=500

# FastAPI 后端绑定地址；0.0.0.0 表示允许从所有本机网络接口访问
BACKEND_HOST=0.0.0.0

# 启动完成后显示给用户的前端访问主机或局域网 IP
FRONTEND_PUBLIC_HOST=192.168.1.66

# 浏览器标签页和页面左上角显示的应用标题
VITE_APP_TITLE=RVizWeb

# 后端日志级别
LOG_LEVEL=INFO

# 是否启用后端调试模式
DEBUG=false

# 允许访问后端 API 的前端来源，多个地址使用英文逗号分隔
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.66:3000

# 配置文件写入接口令牌；留空表示不启用令牌验证
CONFIG_API_TOKEN=

# 单个 .rvizweb 配置文件允许的最大字节数
CONFIG_MAX_BYTES=1048576

# 配置文件名称允许的最大字符数
CONFIG_NAME_MAX_LENGTH=96

# 前端调用配置写入接口时携带的令牌，必须与 CONFIG_API_TOKEN 相同
VITE_CONFIG_API_TOKEN=

# 是否在前端控制台输出调试日志
VITE_DEBUG=false
