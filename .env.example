# ROS2 Web Visualization environment configuration
ROS_DOMAIN_ID=0
ROSBRIDGE_PORT=9090
WEB_PORT=8000
WEB_HOST=0.0.0.0
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.66:3000
# Optional. When set, the frontend must use the same VITE_CONFIG_API_TOKEN.
CONFIG_API_TOKEN=
CONFIG_MAX_BYTES=1048576
CONFIG_NAME_MAX_LENGTH=96
VITE_CONFIG_API_TOKEN=
VITE_DEBUG=false
