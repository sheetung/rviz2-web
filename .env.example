# RViz2 Web Visualization 环境配置示例

# ROS2 环境 setup.bash 路径列表，按顺序 source，空格分隔
# 第一个应为 ROS2 安装目录，后续为各个工作空间
ROS2_SETUP_PATHS="/opt/ros/humble/setup.bash"

# ROS2 通信域 ID；只有相同 Domain ID 的 ROS2 节点才能互相发现
ROS_DOMAIN_ID=0

# FastAPI 后端监听端口
BACKEND_PORT=8000

# Vite 前端开发服务器监听端口
FRONTEND_PORT=3000

# 开发模式文件监听器不足时使用轮询；正常启动模式不使用
CHOKIDAR_USEPOLLING=true

# 开发模式前端文件轮询间隔，单位为毫秒
CHOKIDAR_INTERVAL=500

# FastAPI 后端绑定地址；0.0.0.0 表示允许从所有本机网络接口访问
BACKEND_HOST=0.0.0.0

# 启动完成后显示给用户的前端访问主机或局域网 IP
FRONTEND_PUBLIC_HOST=127.0.0.1

# 启动时默认加载的 .rvizweb 配置文件名
RVIZWEB_CONFIG=default.rvizweb

# 浏览器标签页和页面左上角显示的应用标题
VITE_APP_TITLE=RVizWeb

# 是否启用后端调试模式
DEBUG=false

# 允许访问后端 API 的前端来源，多个地址使用英文逗号分隔
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 配置文件写入接口令牌；留空表示不启用令牌验证
CONFIG_API_TOKEN=

# 单个 .rvizweb 配置文件允许的最大字节数
CONFIG_MAX_BYTES=1048576

# 配置文件名称允许的最大字符数
CONFIG_NAME_MAX_LENGTH=96

# 前端调用配置写入接口时携带的令牌，必须与 CONFIG_API_TOKEN 相同
VITE_CONFIG_API_TOKEN=

# 是否在前端控制台输出调试日志
VITE_DEBUG=false

# RTSP 视频由前端点击工具栏后输入地址，后端使用 FFmpeg 转成浏览器可显示的 MJPEG
RTSP_TRANSPORT=tcp
RTSP_FRAME_RATE=12
RTSP_WIDTH=640
RTSP_JPEG_QUALITY=5
RTSP_STARTUP_TIMEOUT=10
RTSP_SESSION_TTL=300
FFMPEG_PATH=ffmpeg
